# =============================================================================
# Push Project Configuration (Complete)
# 推送项目完整配置文件
# =============================================================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写您的实际值
# 3. 本地运行或Docker运行均使用相同配置
# =============================================================================

# === Environment ===
PUSH_ENV=local           # local | docker | server
TZ=Asia/Shanghai

# === Push Channels (推送渠道) ===
PUSHPLUS_TOKEN=your_pushplus_token_here
SMMS_TOKEN=your_smms_token_here

# === LLM Configuration (AI摘要功能) ===
LLM_PROVIDER=zhipu       # zhipu | gemini | openai
LLM_API_KEY=             # 智谱AI/OpenAI API Key
LLM_BASE_URL=            # 可选:自定义API地址(反向代理)
LLM_MODEL=glm-4-flash    # 模型名称
LLM_PROXY=               # 可选:HTTP代理(仅Gemini需要)

# === Cloudflare D1 (Paper Module) ===
CLOUDFLARE_D1_ACCOUNT_ID=your_account_id
CLOUDFLARE_D1_DATABASE_ID=your_db_id
CLOUDFLARE_D1_API_TOKEN=your_api_token
PAPER_SOURCE_MODE=d1
PAPER_PAST_HOURS=25

# === Optional Services (可选服务) ===

# WebDAV Backup (自动备份)
WEBDAV_URL=https://dav.jianguoyun.com/dav/
WEBDAV_USER=your_email@example.com
WEBDAV_PASS=your_app_password
BACKUP_ENV=test
BACKUP_PASSWORD=your_encryption_password

# GitHub (可选,用于图片上传)
GITHUB_TOKEN=
GITHUB_REPO=

# === Docker Hub / GitHub Container Registry ===
# 用于推送镜像
DOCKER_USERNAME=your_dockerhub_username
DOCKER_REGISTRY=ghcr.io/your_github_username
