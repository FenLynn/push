# =============================================================================
# Push Project Configuration (Complete)
# 推送项目完整配置文件
# =============================================================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写您的实际值
# 3. 本地运行或Docker运行均使用相同配置
# =============================================================================

# === Environment ===
PUSH_ENV=local           # local | docker | server
TZ=Asia/Shanghai

# === Push Channels (推送渠道) ===
PUSHPLUS_TOKEN=your_pushplus_token_here
SMMS_TOKEN=your_smms_token_here

# === LLM Configuration (AI摘要功能) ===
LLM_PROVIDER=zhipu       # zhipu | gemini | openai
LLM_API_KEY=             # 智谱AI/OpenAI API Key
LLM_BASE_URL=            # 可选:自定义API地址(反向代理)
LLM_MODEL=glm-4-flash    # 模型名称
LLM_PROXY=               # 可选:HTTP代理(仅Gemini需要)

# === TTRSS (Tiny Tiny RSS) ===
# Docker环境TTRSS_URL自动设置为http://ttrss-web:80
# 本地环境需手动指定(见下方)
TTRSS_USERNAME=admin
TTRSS_PASSWORD=your_ttrss_password_here

# 本地开发覆盖(仅PUSH_ENV=local时生效)
TTRSS_URL=http://192.168.12.21:1040

# === PostgreSQL Database (TTRSS使用) ===
DB_USER=ttrss
DB_PASS=your_secure_db_password_here
DB_NAME=ttrss

# TTRSS Self URL (Docker内部访问)
SELF_URL_PATH=http://ttrss-web:80/

# === Optional Services (可选服务) ===

# WebDAV Backup (自动备份)
WEBDAV_HOSTNAME=
WEBDAV_LOGIN=
WEBDAV_PASSWORD=

# GitHub (可选,用于图片上传)
GITHUB_TOKEN=
GITHUB_REPO=

# === Docker Hub / GitHub Container Registry ===
# 用于推送镜像
DOCKER_USERNAME=your_dockerhub_username
DOCKER_REGISTRY=ghcr.io/your_github_username

# === Backup Encryption ===
# 备份加密密钥(用于gpg加密私有数据)
BACKUP_GPG_PASSPHRASE=your_strong_passphrase_here
