# =============================================================================
# Push Project Configuration
# 推送项目配置文件
# =============================================================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写您的实际值
# 3. 运行 docker-compose up -d
# =============================================================================

# === Push Channel (必填) ===
PUSHPLUS_TOKEN=your_pushplus_token_here

# === TTRSS Configuration ===
# TTRSS 登录凭据
TTRSS_USER=admin
TTRSS_PASSWORD=your_ttrss_password

# === PostgreSQL Database (for TTRSS) ===
# 数据库配置 - TTRSS 使用
DB_USER=ttrss
DB_PASS=your_secure_db_password
DB_NAME=ttrss

# TTRSS Self URL (用于 Docker 内部通信)
SELF_URL_PATH=http://ttrss-web:80/

# === WebDAV Backup (可选) ===
# 自动备份到 WebDAV 服务器
# 如不需要可留空
WEBDAV_HOSTNAME=
WEBDAV_LOGIN=
WEBDAV_PASSWORD=

# === GitHub (可选，用于图片上传) ===
GITHUB_TOKEN=
GITHUB_REPO=

# === SMMS Image Hosting (可选) ===
SMMS_TOKEN=
