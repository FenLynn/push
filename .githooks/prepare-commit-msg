#!/usr/bin/env python3
import sys
import subprocess
import os

COMMIT_MSG_FILE = sys.argv[1]
SOURCE = sys.argv[2] if len(sys.argv) > 2 else None

def generate_commit_msg():
    try:
        # Get staged files
        result = subprocess.run(["git", "diff", "--name-only", "--cached"], capture_output=True, text=True)
        if result.returncode != 0: return None
        
        files = [f.strip() for f in result.stdout.split("\n") if f.strip()]
        if not files: return None
        
        # Analyze directories
        dirs = set()
        for f in files:
            parts = f.replace("\\", "/").split("/")
            if len(parts) > 1: dirs.add(parts[0])
            
        # Decision Logic
        if all(f.lower().endswith(".md") for f in files): 
            return "Docs: Update documentation"
        elif dirs: 
            return f"Feat: Update {', '.join(sorted(dirs))}"
        else: 
            return "Chore: General updates"
    except Exception as e: 
        return None

def main():
    # Only run if message source is message (command line -m) or None
    # We want to intercept -m "."
    
    # Check if the current message is exactly "."
    try:
        with open(COMMIT_MSG_FILE, "r", encoding="utf-8") as f:
            content = f.read().strip()
            
        if content == ".":
            new_msg = generate_commit_msg()
            if new_msg:
                print(f"[Scigit] Auto-generating message: {new_msg}")
                with open(COMMIT_MSG_FILE, "w", encoding="utf-8") as f:
                    f.write(new_msg)
            else:
                print("[Scigit] Could not generate message (no staged files?).")
    except Exception as e:
        pass

if __name__ == "__main__":
    main()
